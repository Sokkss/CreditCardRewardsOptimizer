<Window x:Class="CreditCardRewardsOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CreditCardRewardsOptimizer"
        mc:Ignorable="d"
        Title="Credit Cards Reward Optimizer" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="10">
            <Label Content="Card Name:" />
            <TextBox x:Name="cardName" />
            <Label Content="List Card Rewards Category Names and Percentages:" />

        </StackPanel>
    </Grid>
</Window>
